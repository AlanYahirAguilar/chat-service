# shell — host de los microfrontends (dominio público)

# ── Requeridas (runtime) ──
# URLs internas de cada zona (Railway private networking, http + puerto)
DASHBOARD_URL=http://dashboard.railway.internal:3001
CONTACTS_URL=http://contacts.railway.internal:3002
COMPOSER_URL=http://composer.railway.internal:3003
# Gateway para el rewrite same-origin de /api
API_URL=http://gateway.railway.internal:4001

# ── Requeridas (build-time, se hornea en el bundle) ──
NEXT_PUBLIC_API_URL=/api
