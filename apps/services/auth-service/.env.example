# auth-service — microservicio TCP interno (sin dominio público)

# ── Requeridas ──
NODE_ENV=production
# La red privada de Railway es IPv6
HOST=::
PORT=4003
# MySQL (referenciar plugin de Railway)
DB_HOST=
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=false
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Redis (sesiones)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Opcionales ──
DB_SYNCHRONIZE=false
