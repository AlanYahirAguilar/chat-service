{
  "name": "syncslot-mail-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "npm-i": "npm cache clean --force && npm install",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "db:create-dev": "ts-node -r dotenv/config src/scripts/create-db.ts",
    "db:create-prod": "node dist/scripts/create-db.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "db:init-prod": "npm run db:create-prod && npm run seed:prod",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "preseed": "npm run db:create-dev",
    "seed": "ts-node -r dotenv/config -r tsconfig-paths/register --project tsconfig.seed.json src/seeds/seed.runner.ts",
    "seed:prod": "node dist/seeds/seed.runner.js"
  },
  "overrides": {
    "protobufjs": "7.2.4"
  },
  "dependencies": {
    "@azure/storage-blob": "12.32.0",
    "@google/generative-ai": "0.24.1",
    "@hapi/boom": "10.0.1",
    "@nestjs-modules/mailer": "2.0.1",
    "@nestjs/cache-manager": "3.1.2",
    "@nestjs/common": "11.0.1",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.0.1",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.1",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.1",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.15.33",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "bcryptjs": "3.0.3",
    "cache-manager": "7.2.8",
    "cache-manager-redis-store": "3.0.1",
    "chokidar": "4.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "handlebars": "4.7.9",
    "ioredis": "5.10.1",
    "mysql": "2.18.1",
    "passport-jwt": "4.0.1",
    "pdfmake": "0.3.8",
    "pino": "10.3.1",
    "qrcode-terminal": "0.12.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "0.3.29",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@types/cache-manager-redis-store": "2.0.4",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.12",
    "@types/multer": "2.1.0",
    "@types/node": "25.7.0",
    "@types/supertest": "7.2.0",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "17.0.0",
    "jest": "29.5.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      ".+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

