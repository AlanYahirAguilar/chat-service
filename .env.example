# ══════════════════════════════════════════════════════════════
# Relay Chat Service — variables de entorno (desarrollo local)
# En Railway cada servicio define SOLO las suyas (ver .env.example
# de cada app y docs/deploy/railway.md). No commitear .env real.
# ══════════════════════════════════════════════════════════════

# ── Generales ─────────────────────────────── (requeridas)
NODE_ENV=development
APP_PORT=4001
# Origen permitido por CORS en producción (URL pública del shell)
APP_URL=http://localhost:3000

# ── Descubrimiento de microservicios TCP ──── (requeridas)
# En Railway: <servicio>.railway.internal y el PORT de cada servicio
USER_SERVICE_HOST=localhost
AUTH_SERVICE_HOST=localhost
IA_SERVICE_HOST=localhost
MAIL_SERVICE_HOST=localhost
TELEGRAM_SERVICE_HOST=localhost
WHATSAPP_SERVICE_HOST=localhost
REDIS_SERVICE_HOST=localhost
USER_SERVICE_PORT=4002
AUTH_SERVICE_PORT=4003
IA_SERVICE_PORT=4004
MAIL_SERVICE_PORT=4005
TELEGRAM_SERVICE_PORT=4006
REDIS_SERVICE_PORT=4008
WHATSAPP_SERVICE_PORT=4011

# ── MySQL (TypeORM) ───────────────────────── (requeridas)
# En Railway: referencias al plugin MySQL (${{MySQL.MYSQLHOST}}, …)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=chat_db
DB_SYNCHRONIZE=true
DB_SSL=false

# ── Redis ─────────────────────────────────── (requeridas)
# En Railway: referencias al plugin Redis (${{Redis.REDISHOST}}, …)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# ── Auth / sesión ─────────────────────────── (requeridas)
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_TTL=900
COOKIE_ACCESS_MAX_AGE=900000
COOKIE_REFRESH_MAX_AGE=604800000

# ── Rate limiting ─────────────────────────── (opcionales)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Integraciones externas ────────────────── (requeridas por servicio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
MAIL_USER=
MAIL_PASSWORD=
TELEGRAM_BOT_TOKEN=
